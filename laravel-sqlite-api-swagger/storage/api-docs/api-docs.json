    "components": {
        "schemas": {
            "Player": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "Name": {
                        "type": "string",
                        "example": "Connor McDavid"
                    },
                    "Team": {
                        "type": "string",
                        "example": "Edmonton Oilers"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            },
            "PlayerRequest": {
                "required": [
                    "Name",
                    "Team"
                ],
                "properties": {
                    "Name": {
                        "type": "string",
                        "example": "Connor McDavid"
                    },
                    "Team": {
                        "type": "string",
                        "example": "Edmonton Oilers"
                    }
                },
                "type": "object"
            },
            "Student": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "FirstName": {
                        "type": "string",
                        "example": "John"
                    },
                    "LastName": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "School": {
                        "type": "string",
                        "example": "CIT"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
