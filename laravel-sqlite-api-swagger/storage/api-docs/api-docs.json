                "properties": {
                    "FirstName": {
                        "type": "string",
                        "example": "John"
                    },
                    "LastName": {
                        "type": "string",
                        "example": "Doe"
                    },
                    "School": {
                        "type": "string",
                        "example": "CST"
                    }
                },
                "type": "object"
            }
        }
